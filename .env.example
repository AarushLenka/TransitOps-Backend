# ============================================================================
# TransitOps environment variables — copy this file to .env and fill in.
# ============================================================================

# NeonDB pooled connection string (PostgreSQL).
# Get it from your Neon project dashboard → "Connection string" → pooled.
# Looks like: postgresql://user:password@ep-xxx-pooled.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Long random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"

# Server
PORT=3000
NODE_ENV=development

# JWT token lifetime
JWT_EXPIRES_IN=12h
