# ============================================================================
# TransitOps environment variables — copy this file to .env and fill in.
# ============================================================================

# NeonDB pooled connection string (PostgreSQL).
# Get it from your Neon project dashboard → "Connection string" → pooled.
# Looks like: postgresql://user:password@ep-xxx-pooled.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Long random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"

# Server
PORT=3000
NODE_ENV=development

# JWT token lifetime
JWT_EXPIRES_IN=12h

# ----------------------------------------------------------------------------
# Upstash Redis (read-through caching) — OPTIONAL.
# Paste your Upstash **Redis** (TLS) connection string below to enable caching of
# the dashboard, reports analytics, and vehicle/driver lookups. Leave it blank to
# keep caching off — the API then runs against Postgres exactly as before.
#   Format: rediss://default:<password>@<name>-<region>.upstash.io:6379
#   (Upstash also exposes a REST URL — do NOT use that here; ioredis needs the
#    native Redis endpoint.)
REDIS_URL=

# Log cache HIT / MISS to the console for debugging hit-rate (optional).
CACHE_DEBUG=false
