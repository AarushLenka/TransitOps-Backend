{
    "info": {
        "_postman_id": "f1a2b3c4-d5e6-7890-abcd-ef1234567890",
        "name": "TransitOps",
        "description": "TransitOps - Smart Transport Operations Platform API.\n\nLogin with any role request below; the test script auto-saves the JWT to the `token` collection variable. All other requests send it as a Bearer token (inherited at the collection level).\n\nSeeded users (password Password123! for all): fleet@transitops.test, driver@transitops.test, safety@transitops.test, finance@transitops.test.\n\nSeeded data: Van-05 (max 500kg), driver Alex, and a Draft 450kg trip - all get id 1, so the default {{vehicleId}} {{driverId}} {{tripId}} variables point at the live data.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{token}}",
                "type": "string"
            }
        ]
    },
