        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "auth": {
                        "type": "noauth"
                    },
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"fullName\": \"New Operator\",\n  \"email\": \"new@transitops.test\",\n  \"password\": \"Password123!\",\n  \"roleId\": 1,\n  \"region\": \"North\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "{{baseUrl}}/api/auth/register"
                    },
                    "response": []
                },
                {
                    "name": "Login - Fleet Manager",
                    "auth": {
                        "type": "noauth"
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "let body;",
                                    "try { body = pm.response.json(); } catch (e) { body = null; }",
                                    "pm.test('Login succeeded', function () {",
                                    "    pm.expect(pm.response.code).to.eql(200);",
                                    "    pm.expect(body).to.have.property('token');",
                                    "});",
                                    "if (body && body.token) {",
                                    "    pm.collectionVariables.set('token', body.token);",
                                    "    console.log('Token saved to collection variable \"token\".');",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
